{
	"name": "@maple/alerting",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "portless",
		"dev:app": "bun run ../../scripts/portless-wrangler.ts --env-file ../../.env.local --persist-to ../api/.wrangler/state --test-scheduled --port ${PORT:-8788} --inspector-port=9231",
		"deploy": "wrangler deploy",
		"test": "echo 'No tests yet'",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@maple-dev/effect-sdk": "workspace:*",
		"@maple/api": "workspace:*",
		"@maple/effect-cloudflare": "workspace:*",
		"effect": "catalog:effect"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260405.0",
		"@effect/language-service": "catalog:effect",
		"@types/node": "catalog:tooling",
		"typescript": "catalog:tooling",
		"wrangler": "^4.41.0"
	},
	"portless": {
		"name": "alerting",
		"script": "dev:app"
	}
}
