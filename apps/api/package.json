{
	"name": "@maple/api",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./alerting": "./src/alerting.ts"
	},
	"scripts": {
		"db:generate": "bun run --cwd ../../packages/db db:generate",
		"dev": "portless",
		"dev:app": "bun run ../../scripts/portless-wrangler.ts --env-file ../../.env.local --port ${PORT:-3472} --inspector-port=$((${PORT:-3472} + 10000))",
		"test": "vitest run",
		"eval": "vitest run --config vitest.eval.config.ts",
		"eval:check": "bun run scripts/eval-runtime-check.ts",
		"measure-tokens": "bun run scripts/measure-token-cost.ts",
		"typecheck": "tsc --noEmit",
		"typecheck:test": "tsc --noEmit -p tsconfig.test.json",
		"tinybird:dev": "tinybird dev",
		"tinybird:build": "tinybird build",
		"tinybird:deploy": "tinybird deploy",
		"bench:fetch": "bun run scripts/bench-queries.ts fetch",
		"bench:run": "bun run scripts/bench-queries.ts run",
		"bench:inspect": "bun run scripts/bench-queries.ts inspect",
		"bench:compare": "bun run scripts/bench-queries.ts compare",
		"bench:startup-cpu": "bun run scripts/bench-startup-cpu.ts"
	},
	"dependencies": {
		"@clerk/backend": "^2.30.1",
		"@clickhouse/client-web": "catalog:clickhouse",
		"@cloudflare/codemode": "^0.4.2",
		"@effect/platform-bun": "catalog:effect",
		"@flue/sdk": "1.0.0-beta.1",
		"@maple-dev/effect-sdk": "workspace:*",
		"@maple/db": "workspace:*",
		"@maple/domain": "workspace:*",
		"@maple/effect-cloudflare": "workspace:*",
		"@maple/email": "workspace:*",
		"@maple/infra": "workspace:*",
		"@maple/query-engine": "workspace:*",
		"@react-email/components": "^1.0.11",
		"@tinybirdco/sdk": "catalog:tinybird",
		"alchemy": "^0.93.12",
		"autumn-js": "^1.2.29",
		"drizzle-orm": "^0.45.1",
		"effect": "catalog:effect"
	},
	"devDependencies": {
		"@ai-sdk/openai-compatible": "^2.0.48",
		"@cloudflare/workers-types": "4.20260603.1",
		"@effect/language-service": "catalog:effect",
		"@electric-sql/pglite": "^0.5.2",
		"@types/node": "catalog:tooling",
		"ai": "^6.0.196",
		"atmn": "^1.0.1",
		"gpt-tokenizer": "^3.0.1",
		"typescript": "catalog:tooling",
		"vitest": "catalog:",
		"vitest-evals": "^0.4.0",
		"wrangler": "^4.41.0"
	},
	"portless": {
		"name": "api",
		"script": "dev:app"
	}
}
