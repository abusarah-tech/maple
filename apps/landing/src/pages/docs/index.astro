---
import { getCollection } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import EffectLogo from "../../components/icons/EffectLogo.astro";
import NodeJsLogo from "../../components/icons/NodeJsLogo.astro";
import NextjsLogo from "../../components/icons/NextjsLogo.astro";
import PythonLogo from "../../components/icons/PythonLogo.astro";
import GoLogo from "../../components/icons/GoLogo.astro";
import RustLogo from "../../components/icons/RustLogo.astro";
import OpenJdkLogo from "../../components/icons/OpenJdkLogo.astro";
import CsharpLogo from "../../components/icons/CsharpLogo.astro";
import KotlinLogo from "../../components/icons/KotlinLogo.astro";

const allDocs = await getCollection("docs", ({ data }) => !data.draft);

const groupBy = (docs: typeof allDocs) => {
    const groups = new Map<string, typeof allDocs>();
    for (const doc of docs) {
        const group = doc.data.group;
        if (!groups.has(group)) groups.set(group, []);
        groups.get(group)!.push(doc);
    }
    for (const [, items] of groups) {
        items.sort((a, b) => a.data.order - b.data.order);
    }
    return groups;
};

const orderGroups = (groups: Map<string, typeof allDocs>, groupOrder: string[]) =>
    [...groups.entries()].sort((a, b) => {
        const ai = groupOrder.indexOf(a[0]);
        const bi = groupOrder.indexOf(b[0]);
        return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
    });

const effectDocs = allDocs.filter((d) => d.data.sdk === "effect");
const languageGuides = allDocs
    .filter((d) => d.data.sdk && d.data.sdk !== "effect")
    .sort((a, b) => {
        if (a.data.order !== b.data.order) return a.data.order - b.data.order;
        return (a.data.sdk ?? "").localeCompare(b.data.sdk ?? "");
    });
const conceptual = allDocs.filter((d) => !d.data.sdk);

const sdkGroups = orderGroups(groupBy(effectDocs), ["Effect SDK", "Platforms"]);
const conceptualGroups = orderGroups(groupBy(conceptual), ["Getting Started", "Concepts", "Infrastructure", "Integrations", "Local Mode"]);

// Language registry for Section 02 — icon, display label, runtime hint
const LANG_META: Record<string, { name: string; Icon: any; meta: string }> = {
    node:   { name: "node.js",  Icon: NodeJsLogo,  meta: "node 18+" },
    nextjs: { name: "next.js",  Icon: NextjsLogo,  meta: "app + pages" },
    python: { name: "python",   Icon: PythonLogo,  meta: "3.9+" },
    go:     { name: "go",       Icon: GoLogo,      meta: "1.21+" },
    rust:   { name: "rust",     Icon: RustLogo,    meta: "stable" },
    java:   { name: "java",     Icon: OpenJdkLogo, meta: "17+" },
    csharp: { name: "c#",       Icon: CsharpLogo,  meta: ".net 8" },
    kotlin: { name: "kotlin",   Icon: KotlinLogo,  meta: "jvm" },
};

// Per-doc runtime/role tag shown right-aligned in the Effect listing.
const META: Record<string, string> = {
    "sdks/overview": "intro",
    "sdks/effect": "setup",
    "sdks/effect-server": "node · bun · deno",
    "sdks/effect-client": "browser",
    "sdks/effect-cloudflare": "workers",
};

// Stat strip values
const totalDocs = allDocs.length;
const totalCollections = 3;
const updated = new Intl.DateTimeFormat("en-US", { year: "numeric", month: "short" })
    .format(new Date())
    .toLowerCase();

const renderTree = (i: number, last: number) => (i === last ? "└──" : "├──");
---

<DocsLayout
    title="Documentation"
    description="Technical documentation for the Maple observability platform."
    headings={[]}
    currentSlug=""
>
    <div class="docs-index">
        {/* ── Header ────────────────────────────────────────────── */}
        <header class="docs-index__head">
            <div class="docs-index__prompt">
                <span class="text-fg-muted">~/maple/docs</span>
                <span class="text-accent">$</span>
                <span class="text-fg-muted">ls -la</span>
                <span class="docs-index__caret" aria-hidden="true"></span>
            </div>

            <div class="flex items-end justify-between gap-6 flex-wrap">
                <h1 class="docs-index__title font-display">Documentation</h1>

                <ul class="docs-index__stats" aria-label="Docs index stats">
                    <li>
                        <span class="docs-index__stat-cap">docs</span>
                        <span class="docs-index__stat-val">{String(totalDocs).padStart(2, "0")}</span>
                    </li>
                    <li>
                        <span class="docs-index__stat-cap">collections</span>
                        <span class="docs-index__stat-val">0{totalCollections}</span>
                    </li>
                    <li>
                        <span class="docs-index__stat-cap">updated</span>
                        <span class="docs-index__stat-val">{updated}</span>
                    </li>
                </ul>
            </div>

            <p class="docs-index__lede">
                Technical documentation for the Maple observability platform — SDKs, OpenTelemetry guides, and the concepts that power the product.
            </p>
        </header>

        {/* ── Section 01 · Effect SDK (drenched amber) ─────────── */}
        <section class="docs-index__band drenched-amber">
            <div class="docs-index__band-inner">
                <div class="docs-index__sec-head">
                    <span class="docs-index__sec-num">#&nbsp;01</span>
                    <span class="docs-index__sec-rule" aria-hidden="true"></span>
                    <div class="docs-index__sec-tile" aria-hidden="true">
                        <EffectLogo class="w-3.5 h-3.5" />
                    </div>
                    <h2 class="docs-index__sec-title font-display">Effect SDK</h2>
                    <span class="docs-index__pill">stable</span>
                    <code class="docs-index__pkg" aria-label="Install command">
                        <span class="opacity-60 mr-1">$</span>npm i @maple-dev/effect-sdk
                    </code>
                </div>

                <p class="docs-index__sec-lede">
                    Official, opinionated wrappers around OpenTelemetry that auto-detect platform conventions. One <code>layer()</code> call ships traces, logs, and metrics from Node, Bun, Deno, the browser, or a Worker.
                </p>

                <div class="docs-index__lists">
                    {sdkGroups.map(([groupName, items]) => (
                        <div class="docs-index__list">
                            <h3 class="docs-index__list-cap">
                                <span class="opacity-60"># </span>{groupName.toLowerCase()}
                            </h3>
                            <ul role="list">
                                {items.map((doc, i) => (
                                    <li>
                                        <a href={`/docs/${doc.id}`} class="docs-row">
                                            <span class="docs-row__tree" aria-hidden="true">{renderTree(i, items.length - 1)}</span>
                                            <span class="docs-row__title">{doc.data.title.toLowerCase()}</span>
                                            <span class="docs-row__desc">{doc.data.description}</span>
                                            <span class="docs-row__meta">{META[doc.id] ?? ""}</span>
                                            <span class="docs-row__arrow" aria-hidden="true">→</span>
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        {/* ── Section 02 · Other languages ─────────────────────── */}
        {languageGuides.length > 0 && (
            <section class="docs-index__section">
                <div class="docs-index__sec-head docs-index__sec-head--dark">
                    <span class="docs-index__sec-num">#&nbsp;02</span>
                    <span class="docs-index__sec-rule" aria-hidden="true"></span>
                    <h2 class="docs-index__sec-title font-display">Other languages</h2>
                    <span class="docs-index__pill docs-index__pill--dark">guides</span>
                </div>

                <p class="docs-index__sec-lede docs-index__sec-lede--dark">
                    Standard OpenTelemetry setup pointed at Maple's ingest endpoint. One guide per language — pick yours and ship traces, logs, and metrics in minutes.
                </p>

                <div class="docs-index__lists">
                    <div class="docs-index__list">
                        <h3 class="docs-index__list-cap docs-index__list-cap--dark">
                            <span class="opacity-60"># </span>instrumentation
                        </h3>
                        <ul role="list">
                            {languageGuides.map((doc) => {
                                const lang = doc.data.sdk ? LANG_META[doc.data.sdk] : undefined;
                                const Icon = lang?.Icon;
                                return (
                                    <li>
                                        <a href={`/docs/${doc.id}`} class="docs-row docs-row--dark docs-row--lang">
                                            <span class="docs-row__icon" aria-hidden="true">
                                                {Icon ? <Icon class="w-3.5 h-3.5" /> : null}
                                            </span>
                                            <span class="docs-row__title">{lang?.name ?? doc.data.sdk ?? doc.data.title.toLowerCase()}</span>
                                            <span class="docs-row__desc">{doc.data.description}</span>
                                            <span class="docs-row__meta">{lang?.meta ?? ""}</span>
                                            <span class="docs-row__arrow" aria-hidden="true">→</span>
                                        </a>
                                    </li>
                                );
                            })}
                        </ul>
                    </div>
                </div>
            </section>
        )}

        {/* ── Section 03 · Concepts ────────────────────────────── */}
        <section class="docs-index__section">
            <div class="docs-index__sec-head docs-index__sec-head--dark">
                <span class="docs-index__sec-num">#&nbsp;03</span>
                <span class="docs-index__sec-rule" aria-hidden="true"></span>
                <h2 class="docs-index__sec-title font-display">Concepts</h2>
                <span class="docs-index__pill docs-index__pill--dark">docs</span>
            </div>

            <p class="docs-index__sec-lede docs-index__sec-lede--dark">
                Language-agnostic explanations of how Maple works — OTLP conventions, sampling-aware throughput, and where to start.
            </p>

            <div class="docs-index__lists">
                {conceptualGroups.map(([groupName, items]) => (
                    <div class="docs-index__list">
                        <h3 class="docs-index__list-cap docs-index__list-cap--dark">
                            <span class="opacity-60"># </span>{groupName.toLowerCase()}
                        </h3>
                        <ul role="list">
                            {items.map((doc, i) => (
                                <li>
                                    <a href={`/docs/${doc.id}`} class="docs-row docs-row--dark">
                                        <span class="docs-row__tree" aria-hidden="true">{renderTree(i, items.length - 1)}</span>
                                        <span class="docs-row__title">{doc.data.title.toLowerCase()}</span>
                                        <span class="docs-row__desc">{doc.data.description}</span>
                                        <span class="docs-row__meta">{META[doc.id] ?? ""}</span>
                                        <span class="docs-row__arrow" aria-hidden="true">→</span>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </section>

        {/* ── Footer rail ──────────────────────────────────────── */}
        <footer class="docs-index__rail">
            <span class="text-fg-muted/70" aria-hidden="true">───</span>
            <span class="text-fg-muted">looking for something specific?</span>
            <a href="https://github.com/Makisuo/maple" class="docs-index__rail-link">github</a>
            <span class="text-fg-muted/40" aria-hidden="true">·</span>
            <a href="https://app.maple.dev" class="docs-index__rail-link">open the app <span aria-hidden="true">→</span></a>
        </footer>
    </div>
</DocsLayout>

<style>
    /* ──────────────────────────────────────────────────────────
       Docs index page — typographic directory listing.
       Reuses tokens from global.css; no new colors / fonts.
       ────────────────────────────────────────────────────────── */
    .docs-index {
        position: relative;
        font-variant-numeric: tabular-nums;
    }

    /* Subtle dot-grid behind the page (matches service-map motif). */
    .docs-index::before {
        content: "";
        position: absolute;
        inset: -32px -64px;
        z-index: -1;
        pointer-events: none;
        background-image: radial-gradient(
            color-mix(in oklab, var(--border) 90%, transparent) 1px,
            transparent 1px
        );
        background-size: 22px 22px;
        background-position: 0 0;
        mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 100%);
        opacity: 0.55;
    }

    /* ── Header ────────────────────────────────────────────── */
    .docs-index__head {
        position: relative;
        padding-bottom: 28px;
        margin-bottom: 36px;
        border-bottom: 1px solid var(--border);
    }
    .docs-index__prompt {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.02em;
        display: inline-flex;
        gap: 8px;
        margin-bottom: 18px;
        align-items: center;
    }
    .docs-index__caret {
        display: inline-block;
        width: 7px;
        height: 11px;
        background: var(--accent);
        animation: caret-blink 1.05s steps(1) infinite;
    }
    .docs-index__title {
        font-family: var(--font-display);
        font-size: clamp(40px, 7vw, 64px);
        line-height: 0.95;
        letter-spacing: -0.035em;
        font-weight: 600;
        color: var(--foreground);
        margin: 0;
    }
    .docs-index__stats {
        display: flex;
        gap: 0;
        list-style: none;
        margin: 0;
        padding: 0;
        border: 1px solid var(--border);
        background: color-mix(in oklab, var(--bg-elevated) 60%, transparent);
    }
    .docs-index__stats li {
        display: flex;
        flex-direction: column;
        padding: 7px 12px;
        min-width: 78px;
        border-right: 1px solid var(--border);
    }
    .docs-index__stats li:last-child {
        border-right: 0;
    }
    .docs-index__stat-cap {
        font-family: var(--font-mono);
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted-foreground);
    }
    .docs-index__stat-val {
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--foreground);
        margin-top: 2px;
    }
    .docs-index__lede {
        margin-top: 22px;
        font-size: 13px;
        line-height: 1.65;
        color: var(--muted-foreground);
        max-width: 56ch;
    }

    /* ── Section heads (shared) ───────────────────────────── */
    .docs-index__sec-head {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }
    .docs-index__sec-num {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.04em;
        opacity: 0.7;
    }
    .docs-index__sec-rule {
        flex: 0 0 36px;
        height: 1px;
        background: currentColor;
        opacity: 0.4;
    }
    .docs-index__sec-tile {
        width: 22px;
        height: 22px;
        background: var(--accent-foreground);
        color: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .docs-index__band .docs-index__sec-tile :global(svg) {
        color: var(--accent);
    }
    .docs-index__sec-title {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.015em;
        margin: 0;
    }
    .docs-index__pill {
        font-family: var(--font-mono);
        font-size: 9px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 3px 7px;
        border: 1px solid currentColor;
        opacity: 0.85;
    }
    .docs-index__pill--dark {
        color: var(--muted-foreground);
        border-color: var(--border);
    }
    .docs-index__pkg {
        font-family: var(--font-mono);
        font-size: 11px;
        margin-left: auto;
        padding: 5px 10px;
        background: color-mix(in oklab, var(--accent-foreground) 14%, transparent);
        border: 1px solid color-mix(in oklab, var(--accent-foreground) 25%, transparent);
        white-space: nowrap;
    }

    /* ── Drenched amber band ──────────────────────────────── */
    .docs-index__band {
        position: relative;
        margin-bottom: 56px;
        overflow: hidden;
    }
    .docs-index__band-inner {
        position: relative;
        z-index: 1;
        padding: 28px 28px 32px;
    }
    .docs-index__sec-lede {
        margin-top: 18px;
        margin-bottom: 26px;
        font-size: 13px;
        line-height: 1.65;
        max-width: 64ch;
        opacity: 0.85;
    }
    .docs-index__sec-lede :global(code) {
        font-family: var(--font-mono);
        font-size: 12px;
        padding: 1px 5px;
        background: color-mix(in oklab, var(--accent-foreground) 14%, transparent);
        border: 1px solid color-mix(in oklab, var(--accent-foreground) 22%, transparent);
    }
    .docs-index__sec-lede--dark :global(code) {
        background: var(--bg-elevated);
        border-color: var(--border);
        color: var(--accent);
    }

    /* ── Section 02 dark head spacing ─────────────────────── */
    .docs-index__section {
        margin-bottom: 48px;
        padding-top: 4px;
    }
    .docs-index__sec-head--dark {
        color: var(--foreground);
    }

    /* ── Group lists (the typographic listings) ───────────── */
    .docs-index__lists {
        display: flex;
        flex-direction: column;
        gap: 26px;
    }
    .docs-index__list ul {
        list-style: none;
        padding: 0;
        margin: 0;
        border-top: 1px solid currentColor;
        border-color: color-mix(in oklab, currentColor 30%, transparent);
    }
    .docs-index__list-cap {
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 0 0 8px;
        opacity: 0.65;
    }
    .docs-index__list-cap--dark {
        color: var(--muted-foreground);
        opacity: 1;
    }

    /* ── Row ──────────────────────────────────────────────── */
    .docs-row {
        display: grid;
        grid-template-columns: 3.5ch minmax(11ch, 18ch) 1fr auto auto;
        gap: 14px;
        align-items: baseline;
        padding: 9px 4px;
        border-bottom: 1px solid color-mix(in oklab, currentColor 18%, transparent);
        text-decoration: none;
        color: inherit;
        position: relative;
        transition: padding-left 160ms cubic-bezier(0.22, 1, 0.36, 1),
                    background-color 160ms ease;
    }
    .docs-row__tree {
        font-family: var(--font-mono);
        font-size: 13px;
        opacity: 0.55;
        transition: opacity 160ms ease, color 160ms ease;
    }
    .docs-row__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        opacity: 0.85;
        color: var(--accent);
        transition: opacity 160ms ease, transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .docs-row__icon :global(svg) {
        width: 14px;
        height: 14px;
    }
    .docs-row--lang:hover .docs-row__icon {
        opacity: 1;
        transform: scale(1.08);
    }
    .docs-row__title {
        font-family: var(--font-mono);
        font-size: 13px;
        font-weight: 500;
        letter-spacing: -0.01em;
        color: currentColor;
    }
    .docs-row__desc {
        font-family: var(--font-sans);
        font-size: 12px;
        line-height: 1.5;
        opacity: 0.72;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .docs-row__meta {
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.06em;
        text-transform: lowercase;
        opacity: 0.55;
        white-space: nowrap;
    }
    .docs-row__arrow {
        font-family: var(--font-mono);
        font-size: 13px;
        opacity: 0.4;
        transform: translateX(0);
        transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1),
                    opacity 160ms ease;
    }

    /* Amber-band hover: cream brightens */
    .docs-index__band .docs-row:hover {
        padding-left: 12px;
        background: color-mix(in oklab, var(--accent-foreground) 8%, transparent);
    }
    .docs-index__band .docs-row:hover .docs-row__tree,
    .docs-index__band .docs-row:hover .docs-row__arrow {
        opacity: 1;
    }
    .docs-index__band .docs-row:hover .docs-row__arrow {
        transform: translateX(4px);
    }

    /* Dark hover: amber accent */
    .docs-row--dark:hover {
        padding-left: 12px;
        background: color-mix(in oklab, var(--accent) 6%, transparent);
    }
    .docs-row--dark:hover .docs-row__tree,
    .docs-row--dark:hover .docs-row__arrow,
    .docs-row--dark:hover .docs-row__title {
        color: var(--accent);
    }
    .docs-row--dark:hover .docs-row__tree,
    .docs-row--dark:hover .docs-row__arrow {
        opacity: 1;
    }
    .docs-row--dark:hover .docs-row__arrow {
        transform: translateX(4px);
    }
    .docs-row--dark:hover .docs-row__desc {
        opacity: 0.95;
    }

    /* ── Footer rail ──────────────────────────────────────── */
    .docs-index__rail {
        font-family: var(--font-mono);
        font-size: 11px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding-top: 18px;
        border-top: 1px solid var(--border);
    }
    .docs-index__rail-link {
        color: var(--muted-foreground);
        transition: color 160ms ease;
        text-decoration: none;
    }
    .docs-index__rail-link:hover {
        color: var(--accent);
    }

    /* ── Responsive: collapse desc + meta on small ────────── */
    @media (max-width: 640px) {
        .docs-row {
            grid-template-columns: 3.5ch 1fr auto;
            row-gap: 4px;
            column-gap: 10px;
        }
        .docs-row__desc {
            grid-column: 2 / 3;
            white-space: normal;
            font-size: 11.5px;
            opacity: 0.65;
        }
        .docs-row__meta {
            display: none;
        }
        .docs-row__arrow {
            grid-row: 1;
            grid-column: 3;
            align-self: center;
        }
        .docs-index__pkg {
            margin-left: 0;
            font-size: 10px;
        }
        .docs-index__band-inner {
            padding: 22px 18px 26px;
        }
        .docs-index__title {
            font-size: clamp(34px, 9vw, 48px);
        }
        .docs-index__stats {
            order: 2;
        }
    }

    @keyframes caret-blink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
    }

    @media (prefers-reduced-motion: reduce) {
        .docs-index__caret { animation: none; opacity: 0.6; }
        .docs-row,
        .docs-row__arrow,
        .docs-row__tree { transition: none; }
    }
</style>
