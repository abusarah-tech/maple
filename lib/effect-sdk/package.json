{
	"name": "@maple-dev/effect-sdk",
	"version": "0.5.0",
	"description": "Maple observability SDK for Effect applications",
	"license": "MIT",
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"exports": {
		".": {
			"node": {
				"types": "./dist/index.server.d.mts",
				"import": "./dist/index.server.mjs"
			},
			"default": {
				"types": "./dist/index.client.d.mts",
				"import": "./dist/index.client.mjs"
			}
		},
		"./server": {
			"types": "./dist/server/index.d.mts",
			"import": "./dist/server/index.mjs"
		},
		"./client": {
			"types": "./dist/client/index.d.mts",
			"import": "./dist/client/index.mjs"
		},
		"./cloudflare": {
			"types": "./dist/cloudflare/index.d.mts",
			"import": "./dist/cloudflare/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"std-env": "^4.0.0"
	},
	"devDependencies": {
		"@effect/language-service": "catalog:effect",
		"@types/node": "catalog:tooling",
		"effect": "catalog:effect",
		"tsdown": "^0.21.7",
		"typescript": "catalog:tooling",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"effect": ">=4.0.0-beta.33"
	}
}
