{
	"name": "@maple-dev/clickhouse-builder",
	"version": "0.1.0",
	"description": "A type-safe, immutable ClickHouse SQL query builder for TypeScript",
	"license": "MIT",
	"keywords": [
		"clickhouse",
		"sql",
		"query-builder",
		"typescript",
		"effect"
	],
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./expr": {
			"types": "./dist/expr.d.mts",
			"import": "./dist/expr.mjs"
		},
		"./types": {
			"types": "./dist/types.d.mts",
			"import": "./dist/types.mjs"
		},
		"./sql": {
			"types": "./dist/sql.d.mts",
			"import": "./dist/sql.mjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepublishOnly": "bun run build"
	},
	"peerDependencies": {
		"effect": ">=4.0.0-beta.33"
	},
	"devDependencies": {
		"@effect/language-service": "catalog:effect",
		"@types/node": "catalog:tooling",
		"effect": "catalog:effect",
		"expect-type": "^1.3.0",
		"tsdown": "^0.21.7",
		"typescript": "catalog:tooling",
		"vitest": "catalog:"
	}
}
