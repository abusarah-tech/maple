{
	"name": "@maple/clickhouse-cli",
	"version": "0.1.0",
	"description": "Apply Maple's ClickHouse schema to a vanilla ClickHouse server. No Maple API required.",
	"keywords": [
		"cli",
		"clickhouse",
		"maple",
		"migration",
		"observability",
		"schema"
	],
	"bin": {
		"maple-ch": "./src/cli.ts"
	},
	"files": [
		"src/**/*.ts",
		"README.md"
	],
	"type": "module",
	"main": "./src/cli.ts",
	"exports": {
		".": "./src/cli.ts"
	},
	"scripts": {
		"start": "bun src/cli.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@maple/domain": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "catalog:tooling",
		"typescript": "catalog:tooling"
	}
}
