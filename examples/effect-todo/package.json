{
	"name": "@maple-examples/effect-todo",
	"version": "0.0.0",
	"private": true,
	"description": "Distributed-tracing demo: React + effect-atom frontend and an Effect (Bun) backend, both instrumented with the Maple SDK and feeding Maple local mode.",
	"type": "module",
	"scripts": {
		"server": "bun run --watch server/main.ts",
		"web": "vite --config web/vite.config.ts",
		"dev": "bun run server & bun run web",
		"typecheck": "tsc -p tsconfig.json && tsc -p web/tsconfig.json"
	},
	"dependencies": {
		"@effect/atom-react": "catalog:effect",
		"@effect/platform-bun": "catalog:effect",
		"@maple-dev/effect-sdk": "workspace:*",
		"effect": "catalog:effect",
		"react": "catalog:react",
		"react-dom": "catalog:react"
	},
	"devDependencies": {
		"@tailwindcss/vite": "catalog:tailwind",
		"@types/bun": "^1.3.11",
		"@types/node": "catalog:tooling",
		"@types/react": "catalog:react",
		"@types/react-dom": "catalog:react",
		"@vitejs/plugin-react": "^6.0.1",
		"tailwindcss": "catalog:tailwind",
		"typescript": "catalog:tooling",
		"vite": "catalog:"
	}
}
